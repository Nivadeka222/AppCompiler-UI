{
  "intent": {
    "app_name": "E-commerce Platform",
    "app_type": "ecommerce",
    "entities": [
      {
        "name": "products",
        "description": "items for sale",
        "attributes": [
          "price",
          "description",
          "image"
        ]
      },
      {
        "name": "carts",
        "description": "temporary storage for products",
        "attributes": [
          "items",
          "total"
        ]
      },
      {
        "name": "orders",
        "description": "completed purchases",
        "attributes": [
          "date",
          "total",
          "status"
        ]
      },
      {
        "name": "payments",
        "description": "financial transactions",
        "attributes": [
          "amount",
          "method"
        ]
      },
      {
        "name": "admin dashboard",
        "description": "backend control panel",
        "attributes": [
          "analytics",
          "settings"
        ]
      }
    ],
    "roles": [
      {
        "name": "admin",
        "permissions": [
          "view analytics",
          "manage settings"
        ]
      },
      {
        "name": "user",
        "permissions": [
          "view products",
          "add to cart",
          "make payment"
        ]
      }
    ],
    "features": [
      {
        "name": "view products",
        "description": "display available products",
        "requires_auth": false,
        "roles_allowed": [
          "user"
        ]
      },
      {
        "name": "add to cart",
        "description": "store products for later purchase",
        "requires_auth": false,
        "roles_allowed": [
          "user"
        ]
      },
      {
        "name": "make payment",
        "description": "complete purchase",
        "requires_auth": false,
        "roles_allowed": [
          "user"
        ]
      },
      {
        "name": "view analytics",
        "description": "display sales data",
        "requires_auth": true,
        "roles_allowed": [
          "admin"
        ]
      },
      {
        "name": "manage settings",
        "description": "configure platform settings",
        "requires_auth": true,
        "roles_allowed": [
          "admin"
        ]
      }
    ],
    "integrations": [
      "payment gateways",
      "shipping providers"
    ],
    "assumptions": [
      "users can create accounts",
      "products have unique IDs"
    ]
  },
  "system_design": {
    "entities": [
      {
        "name": "products",
        "description": "items for sale",
        "attributes": [
          "price",
          "description",
          "image"
        ]
