        ]
      }
    ],
    "relationships": [
      {
        "name": "cart contains products",
        "description": "many-to-many relationship between carts and products",
        "from_entity": "carts",
        "to_entity": "products",
        "type": "many_to_many"
      },
      {
        "name": "order contains products",
        "description": "many-to-many relationship between orders and products",
        "from_entity": "orders",
        "to_entity": "products",
        "type": "many_to_many"
      },
      {
        "name": "payment is related to order",
        "description": "one-to-one relationship between payments and orders",
        "from_entity": "payments",
        "to_entity": "orders",
        "type": "one_to_one"
      },
      {
        "name": "admin dashboard is used by admin",
        "description": "one-to-one relationship between admin dashboard and admin",
        "from_entity": "admin dashboard",
        "to_entity": "admin",
        "type": "one_to_one"
      }
    ],
    "pages": [
      {
        "name": "Product List Page",
        "path": "/products",
        "description": "display available products",
        "access_roles": [
          "user"
        ]
      },
      {
        "name": "Cart Page",
        "path": "/cart",
        "description": "store products for later purchase",
        "access_roles": [
          "user"
        ]
      },
      {
        "name": "Payment Page",
        "path": "/payment",
        "description": "complete purchase",
        "access_roles": [
          "user"
        ]
      },
      {
        "name": "Admin Dashboard",
        "path": "/admin",
        "description": "configure platform settings",
        "access_roles": [
          "admin"
        ]
      }
    ],
    "api_groups": [
      {
        "name": "Product API",
        "description": "manage products",
        "endpoints": [
          {
            "method": "GET",
            "path": "/products",
            "description": "display available products"
          },
          {
            "method": "POST",
            "path": "/products",
            "description": "create new product"
          }
        ]
      },
      {
        "name": "Cart API",
        "description": "manage cart",
        "endpoints": [
          {
            "method": "GET",
            "path": "/cart",
            "description": "display cart contents"
          },
          {
            "method": "POST",
            "path": "/cart",
            "description": "add product to cart"
          }
        ]
      },
      {
        "name": "Order API",
        "description": "manage orders",
        "endpoints": [
          {
            "method": "GET",
            "path": "/orders",
            "description": "display completed orders"
          },
          {
            "method": "POST",
            "path": "/orders",
            "description": "create new order"
          }
        ]
      },
      {
        "name": "Payment API",
        "description": "manage payments",
        "endpoints": [
          {
            "method": "GET",
            "path": "/payments",
            "description": "display completed payments"
          },
          {
            "method": "POST",
            "path": "/payments",
            "description": "create new payment"
          }
        ]
      },
      {
        "name": "Admin API",
        "description": "manage admin dashboard",
        "endpoints": [
          {
            "method": "GET",
            "path": "/admin/analytics",
            "description": "display sales data"
          },
          {
            "method": "POST",
            "path": "/admin/settings",
            "description": "configure platform settings"
          }
        ]
      }
    ],
    "flows": [
      {
        "name": "User Checkout Flow",
        "steps": [
          "User opens Product List Page",
          "User selects product to purchase",
          "User adds product to cart",
          "User views Cart Page",
          "User makes payment",
          "User receives confirmation"
        ]
      },
      {
        "name": "Admin Analytics Flow",
        "steps": [
          "Admin opens Admin Dashboard",
          "Admin views analytics",
          "Admin configures platform settings"
        ]
      }
    ]
  },
